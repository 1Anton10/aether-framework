{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "allowJs": true,
    "checkJs": false,
    "jsx": "preserve"
  },
  "include": ["packages/*/src/**/*.ts"],
  "exclude": [
    "node_modules",
    "dist",
    "target",
    "examples",
    "packages/aether_cli/src/**/*.ts"
  ]
}
